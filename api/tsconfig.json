{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "lib": ["ESNext"],
    "outDir": "build",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@modelcontextprotocol/sdk/server": [
        "node_modules/@modelcontextprotocol/sdk/dist/cjs/server/index"
      ],
      "@modelcontextprotocol/sdk/server/streamableHttp.js": [
        "node_modules/@modelcontextprotocol/sdk/dist/cjs/server/streamableHttp"
      ],
      "@modelcontextprotocol/sdk/types.js": [
        "node_modules/@modelcontextprotocol/sdk/dist/cjs/types"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build"]
}
