generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ListSharePermission {
  READ
  WRITE
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  language   String  @default("en")
  autoTheme  Boolean @default(true)
  darkTheme  String?
  lightTheme String?
  avatarExt  String?
  aiFeaturesDisabled Boolean @default(false)

  lists             List[]
  tasks             Task[]
  tags              Tag[]
  pushSubscriptions PushSubscription[]
  recurringRules    RecurringRule[]
  sharedLists       ListShare[]
  comments          Comment[]
  activities        ActivityLog[]
  assignedTasks     Task[]              @relation("TaskAssignee")
  calendarFeeds     CalendarFeedToken[]
  apiKeys           ApiKey[]
}

model List {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  icon            String?
  color           String?
  category        String?
  commentsEnabled Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tasks                Task[]
  shares               ListShare[]
  calendarFeedMappings CalendarFeedList[]
}

model Task {
  id             String    @id @default(cuid())
  listId         String
  list           List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  dueDate        DateTime?
  dueDateHasTime Boolean   @default(false)
  priority       Priority  @default(NONE)
  done           Boolean   @default(false)
  doneAt         DateTime?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  parentTaskId String?
  parentTask   Task?   @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks     Task[]  @relation("SubTasks")

  tags           TaskTag[]
  recurringRule  RecurringRule?
  reminderSentAt DateTime?
  reminderOffset Int?

  assignedToUserId String?
  assignedTo       User?         @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  comments         Comment[]
  activities       ActivityLog[]
}

model Tag {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  color  String?

  tasks TaskTag[]

  @@unique([userId, name])
}

model TaskTag {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model AppSettings {
  key   String @id
  value String
}

model PushSubscription {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model RecurringRule {
  id        String   @id @default(cuid())
  taskId    String   @unique
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  frequency String
  interval  Int      @default(1)
  streak    Int      @default(0)
  createdAt DateTime @default(now())
}

model ListShare {
  id          String              @id @default(cuid())
  listId      String
  list        List                @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission  ListSharePermission @default(READ)
  invitedById String
  createdAt   DateTime            @default(now())

  @@unique([listId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  listId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model CalendarFeedToken {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  tokenHash   String             @unique
  includeDone Boolean            @default(false)
  isActive    Boolean            @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  lists       CalendarFeedList[]

  @@index([userId, isActive])
}

model CalendarFeedList {
  feedId String
  feed   CalendarFeedToken @relation(fields: [feedId], references: [id], onDelete: Cascade)
  listId String
  list   List              @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([feedId, listId])
  @@index([listId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}
