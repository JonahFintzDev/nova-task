    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.0.0",
    "@sinclair/typebox": "^0.34.33",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.34.0",
